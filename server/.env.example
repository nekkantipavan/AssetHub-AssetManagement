# Approval URL base (your server's IP/domain — used in email links)
APPROVAL_BASE_URL=http://your-server-ip:8080
FRONTEND_BASE_URL=http://your-server-ip:8080
APPROVAL_TOKEN_EXPIRY_HOURS=74
